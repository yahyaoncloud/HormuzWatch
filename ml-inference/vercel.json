{
  "version": 2,
  "functions": {
    "api/predict.py": {
      "runtime": "python3.11",
      "maxDuration": 15,
      "memory": 512
    }
  },
  "routes": [
    {
      "src": "/api/predict",
      "dest": "/api/predict.py",
      "methods": ["POST", "OPTIONS"]
    },
    {
      "src": "/health",
      "dest": "/api/predict.py"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://hormuzwatch.azurestaticapps.net" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ],
  "build": {
    "env": {
      "PYTHON_VERSION": "3.11"
    }
  }
}
