### [NEW] `ml-service/model.py`

```python
import numpy as np
import joblib
import os
import time
from sklearn.ensemble import IsolationForest
from datetime import datetime

FEATURE_COLS = [
    "course_delta", "heading_delta", "speed_delta",
    "average_speed", "speed_variance", "ais_gap_minutes",
    "dist_restricted_zone", "dist_historical_site",
]

MODEL_DIR = "models"
MODEL_PATH = os.path.join(MODEL_DIR, "isolation_forest.joblib")

class AnomalyModel:
    def __init__(self):
        self.model: IsolationForest | None = None
        self.version = "v0.0.0"
        self._load()

    def _load(self):
        if os.path.exists(MODEL_PATH):
            data = joblib.load(MODEL_PATH)
            self.model = data["model"]
            self.version = data["version"]

    def train(self, data: list[dict], contamination: float = 0.05) -> str:
        """Train a new Isolation Forest on the provided feature data."""
        X = np.array([[d[col] for col in FEATURE_COLS] for d in data])

        self.model = IsolationForest(
            n_estimators=200,
            contamination=contamination,
            max_samples="auto",
            random_state=42,
            n_jobs=-1,
        )
        self.model.fit(X)

        self.version = f"v1.{datetime.now().strftime('%Y%m%d%H%M%S')}"
        os.makedirs(MODEL_DIR, exist_ok=True)
        joblib.dump({"model": self.model, "version": self.version}, MODEL_PATH)
        return self.version

    def predict(self, features: dict) -> tuple[float, bool, float]:
        """
        Returns (anomaly_score_0_100, is_anomaly, confidence).
        If no model is trained, returns a neutral score.
        """
        if self.model is None:
            return 0.0, False, 0.0

        X = np.array([[features[col] for col in FEATURE_COLS]])

        # decision_function: negative = anomaly, positive = normal
        raw_score = self.model.decision_function(X)[0]
        prediction = self.model.predict(X)[0]  # 1 = normal, -1 = anomaly

        # Normalize raw_score to 0-100 (more negative = higher anomaly score)
        # Typical range is [-0.5, 0.5]; we map [-0.3, 0.3] → [100, 0]
        normalized = max(0, min(100, (0.3 - raw_score) / 0.6 * 100))
        is_anomaly = prediction == -1
        confidence = min(1.0, abs(raw_score) / 0.3)

        return round(normalized, 2), is_anomaly, round(confidence, 3)
```

