PORT=8080
AUTH_DISABLED=true

# Azure Phase 3 (Optional for Phase 2)
AZURE_TENANT_ID=your-tenant-id
API_AUDIENCE=api://Geospatial-hormuz-watch
GOVERNMENT_API_BASE_URL=https://api.gov.example.com
THIRD_PARTY_API_BASE_URL=https://api.thirdparty.example.com
INTERNAL_API_BASE_URL=http://localhost:8080
EVENT_HUB_CONNECTION_STRING=Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=your-key
EVENT_HUB_NAME=telemetry-hub

# Real-World Data Source APIs (Phase 3)
AISSTREAM_API_KEY=your_aisstream_api_key
OPENSKY_USERNAME=your_opensky_username
OPENSKY_PASSWORD=your_opensky_password
FIRMS_MAP_KEY=your_firms_map_key
