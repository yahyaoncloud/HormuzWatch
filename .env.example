# Render manual deployment (MVP) — set these in each Render web service dashboard
PORT=10000
AUTH_DISABLED=false
JWT_SECRET=change-me-in-production

# Supabase Postgres (Project Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ML service internal URL on Render (https://your-ml-service.onrender.com)
ML_SERVICE_URL=https://your-ml-service.onrender.com

# Comma-separated frontend origins (Vercel URL). Use * only for testing.
ALLOWED_ORIGINS=https://your-app.vercel.app

# Vercel client build variables
VITE_API_URL=https://your-api.onrender.com
VITE_WS_URL=wss://your-api.onrender.com/ws/stream
# Render free tier: use HTTP polling instead of WebSockets
VITE_STREAM_MODE=poll
VITE_POLL_INTERVAL_MS=5000

# Real-World Data Source APIs
AISSTREAM_API_KEY=your_aisstream_api_key
OPENSKY_USERNAME=your_opensky_username
OPENSKY_PASSWORD=your_opensky_password
FIRMS_MAP_KEY=your_firms_map_key

# SMTP notifications (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=alerts@example.com
